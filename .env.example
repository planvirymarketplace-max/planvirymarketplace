# =============================================================================
# Planviry — Environment Variables (TEMPLATE)
# =============================================================================
# Copy this file to .env and fill with real values.
# NEVER commit the real .env file — it contains secrets.
# =============================================================================

# Supabase (Part I §1.1.5 — SOLE database tier)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SESSION_POOLER=postgresql://postgres.your-project:password@aws-1-region.pooler.supabase.com:5432/postgres
SUPABASE_DIRECT_CONNECTION=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
PUBLISHABLE_KEY=sb_publishable_your-key

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Algolia (Part XVII — Search)
NEXT_PUBLIC_ALGOLIA_APP_ID=your-app-id
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=your-search-key
ALGOLIA_ADMIN_KEY=your-admin-key
ALGOLIA_INDEX_NAME=listings
NEXT_PUBLIC_ALGOLIA_LISTINGS_INDEX=listings

# Stripe (Part XI §11.3.4 — Checkout)
STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Resend (Part XXVI — Email channel)
RESEND_API_KEY=re_your-key

# Tinybird (Part XXVII — Analytics)
TINYBIRD_API_URL=https://api.us-east.tinybird.co
TINYBIRD_TOKEN=your-tinybird-token
TINYBIRD_USERNAME=your-workspace

# Geoapify (Part XLIV — Location gate)
NEXT_PUBLIC_GEOAPIFY_API_KEY=your-geoapify-key

# SerpAPI (external search)
SERPAPI_API_KEY=your-serpapi-key

# Ticketmaster (external events)
TICKETMASTER_API_KEY=your-ticketmaster-key

# Site URLs
NEXT_PUBLIC_SITE_URL=https://planviry.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Revalidation
REVALIDATE_SECRET=your-revalidate-secret
REVALIDATION_SECRET=your-revalidation-secret

# Admin seed
ADMIN_SEED_SECRET=your-admin-seed-secret

# GitHub (for CI/CD — store in GitHub Secrets, NOT in .env)
# GITHUB_TOKEN=ghp_your-token

# Databricks (analytics warehouse — if used)
# DATABRICKS_ACCESS_TOKEN=your-token
# DATABRICKS_SERVER_HOST=your-host
# DATABRICKS_HTTP_PATH=your-path
